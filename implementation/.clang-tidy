# Clang-Tidy Configuration for Performance Analysis
# Run: clang-tidy main.cpp -- -std=c++20

Checks: >
  -*,
  performance-*,
  modernize-use-auto,
  modernize-pass-by-value,
  modernize-use-emplace,
  modernize-avoid-bind,
  misc-const-correctness,
  cppcoreguidelines-pro-type-member-init,
  cppcoreguidelines-slicing,
  readability-const-return-type,
  bugprone-move-forwarding-reference,
  bugprone-use-after-move

# Performance checks included:
# - performance-faster-string-find: Use char instead of string for single char finds
# - performance-for-range-copy: Avoid copies in range-based for loops
# - performance-implicit-conversion-in-loop: Detect implicit conversions in loops
# - performance-inefficient-algorithm: Suggest more efficient algorithms
# - performance-inefficient-string-concatenation: Use reserve() or +=
# - performance-inefficient-vector-operation: Use reserve() before push_back loops
# - performance-move-const-arg: Detect useless std::move on const args
# - performance-move-constructor-init: Use std::move in constructor initializers
# - performance-no-automatic-move: Detect missed automatic move opportunities
# - performance-noexcept-destructor: Add noexcept to destructors
# - performance-noexcept-move-constructor: Add noexcept to move constructors
# - performance-trivially-destructible: Use trivially destructible types
# - performance-type-promotion-in-math-fn: Avoid unnecessary type promotions
# - performance-unnecessary-copy-initialization: Avoid unnecessary copies
# - performance-unnecessary-value-param: Use const& instead of value for read-only params
# - misc-const-correctness: Suggest where to add const/constexpr

WarningsAsErrors: ''

HeaderFilterRegex: '.*/Problems/.*'

CheckOptions:
  - key: performance-unnecessary-value-param.AllowedTypes
    value: ''
  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: true
  - key: misc-const-correctness.AnalyzeValues
    value: true
  - key: misc-const-correctness.AnalyzeReferences
    value: true
  - key: misc-const-correctness.WarnPointersAsValues
    value: true
  - key: misc-const-correctness.TransformValues
    value: true
  - key: misc-const-correctness.TransformReferences
    value: true
