{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-debug",
      "type": "shell",
      "command": "clang++",
      "args": [
        "-std=c++20",
        "-I.",
        "-g",
        "-O0",
        "${workspaceFolder}/main.cpp",
        "-o",
        "${workspaceFolder}/main_debug"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"]
    }
  ]
}
